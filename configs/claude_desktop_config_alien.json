{
  "mcpServers": {

    "blender": {
      "command": "uvx",
      "args": ["blender-mcp"]
    },

    "unreal-engine": {
      "type": "http",
      "url": "YOUR_COMPOSIO_MCP_URL",
      "headers": {
        "Authorization": "Bearer YOUR_FLOPPERAM_API_KEY"
      }
    },

    "premiere-pro": {
      "command": "node",
      "args": [
        "C:\\Documents\\MCPs\\Premiere_Pro\\Adobe_Premiere_Pro_MCP\\dist\\index.js"
      ],
      "env": {
        "PREMIERE_TEMP_DIR": "C:\\tmp\\premiere-mcp-bridge"
      }
    },

    "firecrawl-mcp": {
      "command": "node",
      "args": [
        "C:\\Documents\\Firecrawl_MCP\\firecrawl-mcp-server\\dist\\index.js"
      ],
      "env": {
        "FIRECRAWL_API_KEY": "YOUR_FIRECRAWL_API_KEY"
      }
    },

    "remotion": {
      "command": "npx",
      "args": ["@remotion/mcp@latest"]
    },

    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"]
    }

  },

  "preferences": {
    "coworkScheduledTasksEnabled": true,
    "ccdScheduledTasksEnabled": true,
    "sidebarMode": "code"
  }
}

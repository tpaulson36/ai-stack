# .env.example — AI Stack secrets template
# Copy to ~/.claude/.env and fill in your values.
# ~/.claude/.env is never committed.

FIRECRAWL_API_KEY=       # firecrawl.dev → dashboard → API Keys
COMPOSIO_MCP_URL=        # from /connect-apps:setup output
COMPOSIO_API_KEY=        # platform.composio.dev
VERCEL_TOKEN=            # vercel.com/account/tokens
GITHUB_TOKEN=            # github.com/settings/tokens
SUPABASE_URL=            # supabase.com → project → Settings → API
SUPABASE_ANON_KEY=       # supabase.com → project → Settings → API
FLOPPERAM_API_KEY=       # flopperam.com account (Unreal Engine MCP)
